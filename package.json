{
  "name": "offside-labs-studio",
  "version": "0.0.0",
  "private": true,
  "description": "Offside Studio Suite monorepo. CRM is product #1; Crunch / Design / Director follow.",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "codegen:openapi": "node tools/openapi/codegen.mjs",
    "backend:up": "docker compose -f backend/docker-compose.yml up",
    "backend:down": "docker compose -f backend/docker-compose.yml down",
    "ios:gen": "cd frontend-ios && xcodegen generate"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
