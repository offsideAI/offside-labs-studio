# Copy this to .env and edit.
# Local dev defaults match docker-compose.yml.

# --- Django ---
DJANGO_SETTINGS_MODULE=offside_crm.settings.dev
DJANGO_SECRET_KEY=dev-only-replace-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database & cache ---
DATABASE_URL=postgres://offside:dev_only_password@localhost:5432/offside_crm
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
CSRF_TRUSTED_ORIGINS=https://app.offside.ai,https://crm-api.offside.ai,https://platform.offside.ai

# --- Email (Resend) ---
EMAIL_HOST=smtp.resend.com
EMAIL_HOST_USER=resend
RESEND_API_KEY=
EMAIL_PORT=587
DEFAULT_FROM_EMAIL=Offside CRM <noreply@platform.offside.ai>

# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Observability ---
SENTRY_DSN=
DJANGO_ENV=development

# --- Storage (DigitalOcean Spaces / S3-compatible) ---
USE_SPACES=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
